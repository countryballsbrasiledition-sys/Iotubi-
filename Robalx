<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ROBALX 2026 | MULTIPLAYER UPDATE P2P</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: sans-serif; color: white; }
        #ui-login { position: fixed; inset: 0; background: #1b1c1d; z-index: 1000; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; text-align: center; }
        #hud { position: fixed; inset: 0; pointer-events: none; z-index: 100; display: none; }
        .input-box { padding: 12px; margin: 5px; width: 80%; max-width: 300px; border-radius: 5px; border: none; }
        .btn { padding: 15px 30px; background: #0074ff; color: white; border: none; border-radius: 8px; font-weight: bold; margin-top: 10px; width: 85%; max-width: 320px;}
        #my-id-display { color: gold; font-weight: bold; margin: 10px; word-break: break-all; }
        #top-info { position: absolute; top: 10px; width: 100%; text-align: center; font-weight: bold; font-size: 18px; text-shadow: 2px 2px #000; }
        .ctrl { position: absolute; pointer-events: auto; background: rgba(255,255,255,0.1); border: 2px solid #fff; border-radius: 50%; }
        #joy { bottom: 30px; left: 30px; width: 90px; height: 90px; }
        #stick { position: absolute; top: 20px; left: 20px; width: 50px; height: 50px; background: #fff; border-radius: 50%; }
        #jump { bottom: 40px; right: 30px; width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; }
    </style>
</head>
<body>

<div id="ui-login">
    <h1 style="color:gold">ROBALX 2026 🎆</h1>
    <p>Seu ID para amigos:</p>
    <div id="my-id-display">Gerando ID...</div>
    <hr style="width:100%; border: 0.5px solid #444">
    <input type="text" id="friend-id" class="input-box" placeholder="Colar ID do Amigo aqui">
    <button class="btn" onclick="connectToFriend()">CONECTAR AO AMIGO</button>
    <button class="btn" style="background:#02b75a" onclick="startAlone()">JOGAR SOZINHO / HOST</button>
    <p style="font-size:12px; color:#888">Dica: Copie seu ID e mande no WhatsApp do amigo.</p>
</div>

<div id="hud">
    <div id="top-info">LOBBY - AGUARDANDO JOGADORES</div>
    <div id="joy" class="ctrl"><div id="stick"></div></div>
    <div id="jump" class="ctrl">PULO</div>
</div>

<script>
let scene, camera, renderer, player, limbs={}, otherPlayers = {};
let peer, conn, myId;
let mx=0, mz=0, yaw=0, vy=0, gnd=true, timer=30, state="LOBBY";

// --- INICIALIZAÇÃO DO MULTIPLAYER ---
peer = new Peer(); // Cria um ID único no servidor da PeerJS gratuito

peer.on('open', (id) => {
    myId = id;
    document.getElementById('my-id-display').innerText = id;
});

peer.on('connection', (connection) => {
    setupConnection(connection);
});

function connectToFriend() {
    const fId = document.getElementById('friend-id').value;
    if(!fId) return alert("Cole o ID do seu amigo!");
    const connection = peer.connect(fId);
    setupConnection(connection);
    startAlone();
}

function setupConnection(connection) {
    conn = connection;
    conn.on('data', (data) => {
        if(data.type === 'move') updateRemotePlayer(data);
    });
}

function startAlone() {
    document.getElementById('ui-login').style.display = 'none';
    document.getElementById('hud').style.display = 'block';
    init3D();
}

// --- JOGO 3D ---
function init3D() {
    scene = new THREE.Scene(); scene.background = new THREE.Color(0x0a0a2a);
    camera = new THREE.PerspectiveCamera(70, window.innerWidth/window.innerHeight, 0.1, 1000);
    renderer = new THREE.WebGLRenderer({antialias: true});
    renderer.setSize(window.innerWidth, window.innerHeight);
    document.body.appendChild(renderer.domElement);

    scene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const ground = new THREE.Mesh(new THREE.BoxGeometry(400, 5, 400), new THREE.MeshPhongMaterial({color: 0x1a4d13}));
    ground.position.y = -2.5; scene.add(ground);

    const lobby = new THREE.Mesh(new THREE.BoxGeometry(60, 2, 60), new THREE.MeshPhongMaterial({color: 0x333333}));
    lobby.position.y = 100; scene.add(lobby);

    createPlayer();
    setupMobileControls();
    animate();
    setInterval(tick, 1000);
}

function createPlayer() {
    player = new THREE.Group();
    const mat = new THREE.MeshLambertMaterial({color: 0xffff00});
    const torso = new THREE.Mesh(new THREE.BoxGeometry(2, 2.5, 1.2), new THREE.MeshLambertMaterial({color: 0x0055ff}));
    torso.position.y = 3.5;
    player.add(torso);
    player.position.y = 101; scene.add(player);
}

function createOtherPlayer(id) {
    const g = new THREE.Group();
    const torso = new THREE.Mesh(new THREE.BoxGeometry(2, 2.5, 1.2), new THREE.MeshLambertMaterial({color: 0xff0000}));
    torso.position.y = 3.5;
    g.add(torso);
    scene.add(g);
    otherPlayers[id] = g;
}

function updateRemotePlayer(data) {
    if(!otherPlayers[data.id]) createOtherPlayer(data.id);
    otherPlayers[data.id].position.set(data.x, data.y, data.z);
    otherPlayers[data.id].rotation.y = data.ry;
}

function animate() {
    requestAnimationFrame(animate);
    let floor = (state === "LOBBY") ? 101 : 0;

    vy -= 0.05; player.position.y += vy;
    if(player.position.y < floor) { player.position.y = floor; vy = 0; gnd = true; }

    if(mx || mz) {
        const v = new THREE.Vector3(mx, 0, mz).applyAxisAngle(new THREE.Vector3(0,1,0), yaw);
        player.position.add(v.multiplyScalar(0.7));
        player.rotation.y = Math.atan2(v.x, v.z);
    }

    camera.position.set(player.position.x + Math.sin(yaw)*40, player.position.y+25, player.position.z + Math.cos(yaw)*40);
    camera.lookAt(player.position.x, player.position.y+5, player.position.z);

    // Enviar dados para o amigo
    if(conn && conn.open) {
        conn.send({
            type: 'move', id: myId,
            x: player.position.x, y: player.position.y, z: player.position.z,
            ry: player.rotation.y
        });
    }

    renderer.render(scene, camera);
}

function tick() {
    timer--;
    if(timer <= 0) {
        state = (state === "LOBBY") ? "DESASTRE" : "LOBBY";
        timer = state === "LOBBY" ? 20 : 60;
        player.position.set(0, state === "LOBBY" ? 102 : 5, 0);
    }
    document.getElementById('top-info').innerText = `${state} - ${timer}s`;
}

function setupMobileControls() {
    window.addEventListener('touchmove', e => {
        const t = e.touches[0];
        if(t.clientX < window.innerWidth/2) {
            const dx = t.clientX-75, dy = t.clientY-(window.innerHeight-75);
            const d = Math.min(Math.hypot(dx,dy), 40), a = Math.atan2(dy,dx);
            mx = Math.cos(a)*(d/40); mz = Math.sin(a)*(d/40);
            document.getElementById('stick').style.transform = `translate(${Math.cos(a)*d}px, ${Math.sin(a)*d}px)`;
        } else { yaw -= (t.clientX - (window.lx||t.clientX))*0.008; window.lx=t.clientX; }
    });
    window.addEventListener('touchend', () => { mx=mz=0; window.lx=null; document.getElementById('stick').style.transform=''; });
    document.getElementById('jump').onclick = () => { if(gnd) { vy=0.8; gnd=false; } };
}
</script>
</body>
</html>
